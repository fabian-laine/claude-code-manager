{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "claude-code-manager",
  "version": "0.2.0",
  "identifier": "com.existe.claudecodemanager",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Claude Code Manager",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "DeveloperTool",
    "shortDescription": "Manager for Claude Code sessions",
    "longDescription": "Manage multiple Claude Code sessions across projects from a single dark-themed desktop app.",
    "resources": {
      "../build": "build"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "rpm": {
        "desktopTemplate": "assets/claude-code-manager.desktop"
      },
      "deb": {
        "desktopTemplate": "assets/claude-code-manager.desktop"
      }
    }
  }
}
